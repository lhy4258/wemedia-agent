DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/wemedia-agent
REDIS_URL=redis://localhost:6379/0
MODEL_USE_SYSTEM_PROXY=false
LLM_MOCK=true
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4.1-mini
LLM_TEMPERATURE=0.4
LLM_TOP_P=0.9
LLM_MAX_TOKENS=1600
LLM_PRESENCE_PENALTY=0.1
LLM_FREQUENCY_PENALTY=0.1
LLM_TIMEOUT_SECONDS=30
IMAGE_MOCK=true
IMAGE_API_KEY=
IMAGE_BASE_URL=https://api.openai.com/v1
IMAGE_MODEL=gpt-image-1
EMBED_MOCK=true
EMBED_API_KEY=
EMBED_BASE_URL=https://api.openai.com/v1
EMBED_MODEL=text-embedding-3-small
EMBED_DIMENSION=1536
CHECKPOINTER_MOCK=false
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=wemedia-agent-dev
FIRECRAWL_ENABLED=false
FIRECRAWL_API_KEY=
FIRECRAWL_BASE_URL=https://api.firecrawl.dev/v2
FIRECRAWL_TIMEOUT_SECONDS=60
FIRECRAWL_MAX_RESULTS=8
WECHAT_PUBLISH_MOCK=true
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_API_BASE_URL=https://api.weixin.qq.com
WECHAT_TOKEN_CACHE_SECONDS=7000
WECHAT_DEFAULT_THUMB_MEDIA_ID=
WECHAT_PUBLISH_DEFAULT_MODE=draft
